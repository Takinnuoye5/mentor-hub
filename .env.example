# ============================================================================
# SLACK CONFIGURATION
# ============================================================================
# Slack Bot Token (scope: chat:write, chat:postEphemeral, conversations:open, users:read)
# Generate from: https://api.slack.com/apps/<YOUR_APP_ID>/install-org
SLACK_BOT_TOKEN_HNG14=xoxb-your-bot-token-here

# Slack User Token (scope: users:read, users:read.email)
# Generate from same location with user oauth
SLACK_USER_TOKEN_HNG14=xoxp-your-user-token-here

# Slack App Signing Secret (for webhook signature verification)
# Generate from: https://api.slack.com/apps/<YOUR_APP_ID>/basic-information
SLACK_SIGNING_SECRET_HNG14=your-signing-secret-here

# ============================================================================
# GOOGLE SHEETS CONFIGURATION
# ============================================================================
# Path to Google service account credentials JSON file
# Download from: Google Cloud Console > Select Project > Service Accounts > Create Key (JSON)
# This file contains the credentials needed to access Google Sheets API
GOOGLE_CREDENTIALS_FILE=/path/to/service-account-credentials.json

# Name of the Google Sheets spreadsheet to use for storing mentor track selections
GOOGLE_SPREADSHEET_NAME=HNG 14 Mentor Track Selection

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Server port (default: 3000)
SERVER_PORT=3000

# API request timeout in seconds (for Slack API calls)
API_REQUEST_TIMEOUT=5

# ============================================================================
# FEATURE FLAGS & SETTINGS
# ============================================================================
# Enable testing mode (prevents actual Slack notifications, just logs them)
TESTING_MODE=false

# Log instead of sending notifications (useful for testing)
LOG_INSTEAD_OF_NOTIFY=false

# Disable admin channel notifications (mentors still get DM confirmation)
DISABLE_ADMIN_NOTIFICATIONS=true

# Debug level: standard, verbose, debug
DEBUG_LEVEL=standard
# Slack Tokens (HNG14 Workspace)
SLACK_BOT_TOKEN_HNG14=xoxb-your-bot-token
SLACK_USER_TOKEN_HNG14=xoxp-your-user-token
SLACK_SIGNING_SECRET_HNG14=your-signing-secret

# Google Sheets Configuration
GOOGLE_CREDENTIALS_FILE=C:/path/to/your-credentials.json
GOOGLE_SPREADSHEET_NAME=HNG Mentor Track Selection
GOOGLE_WORKSHEET_PREFIX=Mentors

# System Settings
TESTING_MODE=false
LOG_INSTEAD_OF_NOTIFY=false
DEBUG_LEVEL=standard

# Active Workspace
ACTIVE_WORKSPACE=HNG14

# Server Configuration (optional)
HOST=0.0.0.0
PORT=8000
DEBUG=false
